<Window x:Class="MusicPlayer.Windows.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Player" 
        Height="120" 
        Width="300"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    
    <Border CornerRadius="12"
            Background="#1E1E2E"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <BlurEffect Radius="0" />
        </Border.Effect>
        
        <Grid>
            <Grid Height="32" 
                  VerticalAlignment="Top"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Mini Player"
                           Foreground="#CDD6F4"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0" />
                
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="□" Click="SwitchToMain_Click"
                            Width="32" Height="32"
                            Background="Transparent"
                            Foreground="#CDD6F4"
                            BorderThickness="0" />
                    <Button Content="✕" Click="CloseButton_Click"
                            Width="32" Height="32"
                            Background="Transparent"
                            Foreground="#CDD6F4"
                            BorderThickness="0" />
                </StackPanel>
            </Grid>
            
            <StackPanel Margin="10,32,10,10">
                <TextBlock Text="{Binding CurrentSong.Title, FallbackValue='未播放歌曲'}"
                           Foreground="#CDD6F4"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5" />
                <TextBlock Text="{Binding CurrentSong.Artist, FallbackValue='未知艺术家'}"
                           Foreground="#88FFFFFF"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />
                
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="⏮"
                            Command="{Binding PlayPreviousCommand}"
                            Width="30" Height="30"
                            Background="Transparent"
                            Foreground="#CDD6F4"
                            BorderThickness="0" />
                    <Button Content="{Binding PlayButtonContent}"
                            Command="{Binding PlayPauseCommand}"
                            Width="40" Height="40"
                            Background="#89B4FA"
                            Foreground="#1E1E2E"
                            BorderThickness="0"
                            Margin="10,0" />
                    <Button Content="⏭"
                            Command="{Binding PlayNextCommand}"
                            Width="30" Height="30"
                            Background="Transparent"
                            Foreground="#CDD6F4"
                            BorderThickness="0" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
