<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MusicPlayer.ViewModels"
        Title="Music Player" 
        Height="750" 
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">
    
    <Window.InputBindings>
        <KeyBinding Key="Space" Command="{Binding PlayPauseCommand}" />
        <KeyBinding Key="Right" Command="{Binding PlayNextCommand}" />
        <KeyBinding Key="Left" Command="{Binding PlayPreviousCommand}" />
        <KeyBinding Key="Up" Command="{Binding VolumeUpCommand}" />
        <KeyBinding Key="Down" Command="{Binding VolumeDownCommand}" />
        <KeyBinding Key="M" Command="{Binding SwitchToMiniModeCommand}" />
    </Window.InputBindings>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    
    <Border CornerRadius="14" Background="#000000" BorderBrush="#1FFFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="Music" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="⊡" Click="SwitchToMini_Click" Width="38" Height="28" Background="Transparent" Foreground="#666666" BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button Content="—" Click="MinimizeButton_Click" Width="38" Height="28" Background="Transparent" Foreground="#666666" BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button Content="□" Click="MaximizeButton_Click" Width="38" Height="28" Background="Transparent" Foreground="#666666" BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button Content="✕" Click="CloseButton_Click" Width="38" Height="28" Background="Transparent" Foreground="#666666" BorderThickness="0" FontSize="12" Cursor="Hand"/>
                </StackPanel>
            </Grid>
            
            <!-- 主内容 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧栏 -->
                <Border Grid.Column="0" Background="#0A0A0A" CornerRadius="0,0,0,14">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 添加按钮 -->
                        <StackPanel Grid.Row="0" Margin="16,0,16,16">
                            <Border Background="#FF3B30" CornerRadius="10" Margin="0,0,0,8">
                                <Button Content="添加歌曲" Command="{Binding AddFilesCommand}" 
                                        Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"
                                        FontWeight="SemiBold" FontSize="13" Padding="0,9" Cursor="Hand"/>
                            </Border>
                            <Border Background="#1C1C1E" CornerRadius="10">
                                <Button Content="添加文件夹" Command="{Binding AddFolderCommand}" 
                                        Background="Transparent" Foreground="#8E8E93" BorderThickness="0"
                                        FontSize="12" Padding="0,7" Cursor="Hand"/>
                            </Border>
                        </StackPanel>
                        
                        <!-- 搜索框 -->
                        <Border Grid.Row="1" Margin="12,4,12,4" Background="#1C1C1E" CornerRadius="8">
                            <Grid Margin="8,0">
                                <TextBlock Text="🔍 搜索歌曲" Foreground="#48484A" FontSize="12" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                    </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="SearchBox" Background="Transparent" Foreground="#FFFFFF" 
                                         BorderThickness="0" FontSize="12" Padding="0,6"
                                         TextChanged="SearchBox_TextChanged"/>
                            </Grid>
                        </Border>
                        
                        <!-- 歌曲列表 -->
                        <ListBox Grid.Row="2" ItemsSource="{Binding Songs}" SelectedItem="{Binding CurrentSong}"
                                 Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"
                                 Margin="8,0" x:Name="SongListBox"
                                 MouseDoubleClick="SongListBox_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="4,0" Height="44" VerticalAlignment="Center">
                                        <StackPanel DockPanel.Dock="Left" Width="150" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}" FontSize="11" Foreground="#8E8E93" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <Button Content="↑" Command="{Binding DataContext.MoveSongUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#48484A" BorderThickness="0" Width="16" FontSize="9" Cursor="Hand"/>
                                            <Button Content="↓" Command="{Binding DataContext.MoveSongDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#48484A" BorderThickness="0" Width="16" FontSize="9" Cursor="Hand"/>
                                            <Button Content="×" Command="{Binding DataContext.RemoveSongCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#48484A" BorderThickness="0" Width="16" FontSize="10" Cursor="Hand"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#14FFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#1C1C1E"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        
                        <!-- 播放列表 -->
                        <Border Grid.Row="3" Background="#111111" CornerRadius="0,0,0,14" Padding="14,12" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="播放列表" Foreground="#FFFFFF" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBox Text="{Binding NewPlaylistName}" Width="96" Background="#1C1C1E" Foreground="#FFFFFF" BorderBrush="#2C2C2E" Padding="6,5" FontSize="11" Margin="0,0,6,0"/>
                                    <Button Content="保存" Command="{Binding SavePlaylistCommand}" Background="#FF3B30" Foreground="#FFFFFF" BorderThickness="0" Padding="12,5" FontWeight="SemiBold" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding Playlists}" SelectedItem="{Binding CurrentPlaylist}" MaxHeight="80" Background="Transparent" Foreground="#8E8E93" BorderThickness="0" FontSize="11">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                <Button Content="×" Command="{Binding DataContext.DeletePlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#48484A" BorderThickness="0" DockPanel.Dock="Right" Width="16" FontSize="9" Cursor="Hand"/>
                                                <Button Content="▶" Command="{Binding DataContext.LoadPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#8E8E93" BorderThickness="0" DockPanel.Dock="Right" Width="16" FontSize="9" Cursor="Hand"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- 右侧主区域 -->
                <Grid Grid.Column="1">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#1C1C1E" Offset="0"/>
                            <GradientStop Color="#000000" Offset="0.6"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    
                    <!-- 内容 -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,0">
                        <!-- 专辑封面 -->
                        <Border Width="280" Height="280" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,32"
                                Background="#1C1C1E">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="50" Opacity="0.35" ShadowDepth="10" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Image Source="{Binding CurrentCoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,280,280" RadiusX="16" RadiusY="16"/>
                                    </Image.Clip>
                                </Image>
                                <TextBlock Text="♫" FontSize="56" Foreground="#FF3B30" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"
                                           Visibility="{Binding CurrentCoverPath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,20">
                                    <TextBlock Text="{Binding CurrentSong.Title, FallbackValue='未播放歌曲'}" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding CurrentSong.Artist, FallbackValue='未知艺术家'}" Foreground="#8E8E93" FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- 歌词 -->
                        <Border MaxWidth="460" Padding="20,14" CornerRadius="12" Background="#14FFFFFF">
                            <TextBlock Text="{Binding CurrentLyricText, FallbackValue='暂无歌词'}" 
                                       Foreground="#FFFFFF" FontSize="17"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" LineHeight="26"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
            
            <!-- 底部播放栏 -->
            <Border Grid.Row="2" Background="#1C1C1E" CornerRadius="0,0,14,14" Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左：歌曲信息 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" CornerRadius="8" Background="#2C2C2E" Margin="0,0,12,0">
                            <TextBlock Text="♫" FontSize="18" Foreground="#FF3B30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentSong.Title, FallbackValue='未播放'}" Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                            <TextBlock Text="{Binding CurrentSong.Artist, FallbackValue='--'}" Foreground="#8E8E93" FontSize="10" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- 中：播放控制 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <Border Width="36" Height="36" CornerRadius="18" Background="#1C1C1E" Margin="0,0,12,0">
                                <Button Content="|◁" Command="{Binding PlayPreviousCommand}" Width="36" Height="36" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
                            </Border>
                            <Border Width="42" Height="42" CornerRadius="21" Background="#FFFFFF" Margin="0,0,12,0">
                                <Button Content="{Binding PlayButtonContent}" Command="{Binding PlayPauseCommand}" 
                                        Width="42" Height="42" Background="Transparent" Foreground="#000000" 
                                        BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand"/>
                            </Border>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#1C1C1E">
                                <Button Content="▷|" Command="{Binding PlayNextCommand}" Width="36" Height="36" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
                            </Border>
                        </StackPanel>
                        <Grid HorizontalAlignment="Center" Width="520">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CurrentPosition, StringFormat='{}{0:mm\\:ss}'}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                            <Slider Grid.Column="1" Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" 
                                    ValueChanged="ProgressSlider_ValueChanged" Margin="10,0" VerticalAlignment="Center"
                                    PreviewMouseLeftButtonUp="ProgressSlider_MouseLeftButtonUp"/>
                            <TextBlock Grid.Column="2" Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- 右：音量 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="🔊" FontSize="12" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Value="{Binding Volume}" Width="80" Minimum="0" Maximum="1" 
                                TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
